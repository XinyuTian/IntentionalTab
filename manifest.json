{
  "manifest_version": 3,
  "name": "IntentionalTab",
  "version": "0.1.0",
  "description": "Open distracting sites on purpose: a reason, a time limit, and a daily budget.",
  "permissions": ["storage", "tabs", "alarms", "scripting", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "IntentionalTab — open settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
